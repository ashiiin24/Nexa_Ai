DJANGO_SECRET_KEY=change-this-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=

# Render production example:
# DJANGO_SECRET_KEY=use-render-generated-secret
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=your-app-name.onrender.com
# DATABASE_URL=postgresql://...

# Default behavior
DEFAULT_PROVIDER=groq
DEFAULT_OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# Cloud API keys. Add only the providers you use.
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Optional default models
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
GEMINI_DEFAULT_MODEL=gemini-2.0-flash
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
ANTHROPIC_DEFAULT_MODEL=claude-3-5-haiku-latest
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.1-8b-instruct

# Google OAuth needs a Social App in Django admin:
# Provider: Google, Client id/secret from Google Cloud Console, Sites: 127.0.0.1:8000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
